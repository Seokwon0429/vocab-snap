# 서버는 Tailscale Funnel 뒤의 로컬 주소에서만 수신합니다.
WORDLENS_HOST=127.0.0.1
WORDLENS_PORT=8787

# 쉼표로 여러 프론트엔드 Origin을 허용할 수 있습니다. 경로는 넣지 않습니다.
WORDLENS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://seokwon0429.github.io

# invite(권장), open(누구나 가입), closed(신규 가입 중지) 중 하나를 고릅니다.
WORDLENS_REGISTRATION_MODE=invite

# invite 모드에서 비워 두면 서버를 켤 때 임시 초대 코드를 생성해 터미널에 표시합니다.
# 같은 코드를 계속 쓰려면 추측하기 어려운 긴 값을 직접 넣습니다.
WORDLENS_INVITE_CODE=

# 로그인 유지 기간과 SQLite 파일 위치입니다.
WORDLENS_SESSION_DAYS=30
WORDLENS_DB_PATH=server/data/wordlens.sqlite

# 공개 가입 악용으로 저장 공간이 가득 차는 것을 막는 기본 상한입니다.
WORDLENS_MAX_USERS=50
WORDLENS_MAX_WORDS_PER_USER=20000
WORDLENS_MAX_FOLDERS_PER_USER=500
WORDLENS_MAX_DATABASE_BYTES=1073741824
